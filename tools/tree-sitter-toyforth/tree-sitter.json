{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "toyforth",
      "camelcase": "Toyforth",
      "title": "Toyforth",
      "scope": "source.toyforth",
      "file-types": [
        ".tf",
        ".fth"
      ],
      "injection-regex": "^toyforth$",
      "class-name": "TreeSitterToyforth"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Toyforth grammar for tree-sitter",
    "authors": [
      {
        "name": "Lorenzo287",
        "url": ""
      }
    ]
  },
  "bindings": {
    "c": false,
    "go": false,
    "java": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
