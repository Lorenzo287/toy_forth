[ 10 20 < ] [ "10 is less than 20\n" print ] if
[ 30 20 < ] [ "30 is less than 20\n" print ] [ "30 is not less than 20\n" print ] ifelse

5 [ [ 0 > ] [ "positive" println ] [ "non-positive" println ] ifelse ] exec
-5 [ [ 0 > ] [ "positive" println ] [ "non-positive" println ] ifelse ] exec

[ 1 2 + ] exec println
